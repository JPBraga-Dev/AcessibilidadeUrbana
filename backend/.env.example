# URL do projeto Supabase (Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co

# Service Role Key — NUNCA exponha no frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Segredo para assinar JWTs — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio

# Duração do token (ex: 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# Porta do servidor
PORT=3000
